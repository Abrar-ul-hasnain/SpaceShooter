{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build SpaceShooter",
      "type": "shell",
      "command": "g++",
      "args": [
        "-g",
        "main.cpp",
        "src/*.cpp",
        "-IC:/SFML-3.0.0/include",
        "-LC:/SFML-3.0.0/lib",
        "-lsfml-graphics",
        "-lsfml-window",
        "-lsfml-system",
        "-lsfml-audio",
        "-o",
        "SpaceShooter"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}